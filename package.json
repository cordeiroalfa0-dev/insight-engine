{
  "name": "master-games-arcade",
  "private": true,
  "version": "1.0.0",
  "description": "Master Games Arcade - MAME Launcher (dev emerson 2026)",
  "author": "dev emerson 2026",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:pack": "vite build && electron-packager . MasterGamesArcade --platform=win32 --arch=x64 --out=electron-release --overwrite --ignore=\"^/src\" --ignore=\"^/public/intro\" --ignore=\"^/electron-release\" --ignore=\"^/python-tools\"",
    "prebuild:installer": "node scripts/make-icon.cjs",
    "build:installer": "npm run prebuild:installer && npm run build && electron-builder --win nsis-web --x64",
    "build:installer-full": "npm run prebuild:installer && npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "@fontsource/vt323": "^5.2.7",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-spring/web": "^10.0.4",
    "@tanstack/react-virtual": "^3.13.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "howler": "^2.2.4",
    "localforage": "^1.10.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-lazy-load-image-component": "^1.6.3",
    "react-router-dom": "^6.27.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/howler": "^2.2.13",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-lazy-load-image-component": "^1.6.5",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^2.1.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.2"
  },
  "build": {
    "appId": "com.emerson.mastergamesarcade",
    "productName": "Master Games Arcade",
    "copyright": "Copyright © 2026 dev emerson",
    "directories": {
      "buildResources": "build",
      "output": "electron-release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "mame-server.js",
      "package.json",
      "!python-tools/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      { "from": "mame-server.js", "to": "mame-server.js" }
    ],
    "win": {
      "target": [{ "target": "nsis-web", "arch": ["x64"] }],
      "icon": "build/icon.ico",
      "artifactName": "MasterGamesArcade-Setup-${version}.${ext}"
    },
    "nsisWeb": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Master Games Arcade",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "include": "build/installer.nsh"
    },
    "publish": null
  }
}
